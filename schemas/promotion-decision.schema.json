{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://effort-router.local/schemas/promotion-decision.schema.json",
  "title": "Promotion decision",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version", "gates_version", "prompt_policy_promotion", "rust",
    "benchmark", "retained_dataset"
  ],
  "$defs": {
    "decision": {
      "type": "object",
      "additionalProperties": false,
      "required": ["approved", "reasons"],
      "properties": {
        "approved": { "type": "boolean" },
        "reasons": {
          "type": "array",
          "items": { "$ref": "common.schema.json#/$defs/nonEmptyString" },
          "uniqueItems": true
        }
      }
    }
  },
  "properties": {
    "schema_version": { "const": "1.0.0" },
    "gates_version": { "$ref": "common.schema.json#/$defs/nonEmptyString" },
    "prompt_policy_promotion": { "$ref": "#/$defs/decision" },
    "rust": { "$ref": "#/$defs/decision" },
    "benchmark": { "$ref": "common.schema.json#/$defs/nonEmptyString" },
    "retained_dataset": { "$ref": "common.schema.json#/$defs/nonEmptyString" }
  }
}