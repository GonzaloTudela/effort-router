{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://effort-router.local/schemas/task-profile.schema.json",
  "title": "TaskProfile",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "id",
    "contract_status",
    "missing_fields",
    "operation",
    "description",
    "targets",
    "change_surface",
    "constraints",
    "acceptance",
    "context_roots",
    "dependencies",
    "conflict_keys",
    "quality_target",
    "ambiguities",
    "field_provenance"
  ],
  "properties": {
    "schema_version": { "const": "1.0.0" },
    "id": { "$ref": "common.schema.json#/$defs/nonEmptyString" },
    "contract_status": { "type": "string", "enum": ["complete", "incomplete"] },
    "missing_fields": {
      "type": "array",
      "items": { "$ref": "common.schema.json#/$defs/nonEmptyString" },
      "uniqueItems": true
    },
    "operation": {
      "type": "string",
      "enum": ["inspect", "fix", "refactor", "migrate", "test", "generate"]
    },
    "description": { "$ref": "common.schema.json#/$defs/nonEmptyString" },
    "targets": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["path", "symbol"],
        "properties": {
          "path": { "$ref": "common.schema.json#/$defs/nonEmptyString" },
          "symbol": {
            "anyOf": [
              { "$ref": "common.schema.json#/$defs/nonEmptyString" },
              { "type": "null" }
            ]
          }
        }
      }
    },
    "change_surface": {
      "type": "string",
      "enum": ["body", "signature", "callers", "data_contract", "architecture"]
    },
    "constraints": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["kind", "subject", "expected"],
        "properties": {
          "kind": { "$ref": "common.schema.json#/$defs/nonEmptyString" },
          "subject": { "$ref": "common.schema.json#/$defs/nonEmptyString" },
          "expected": {}
        }
      }
    },
    "acceptance": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["kind", "command_or_assertion", "executable"],
        "properties": {
          "kind": { "type": "string", "enum": ["command", "assertion", "test", "manual"] },
          "command_or_assertion": { "$ref": "common.schema.json#/$defs/nonEmptyString" },
          "executable": { "type": "boolean" }
        }
      }
    },
    "context_roots": {
      "type": "array",
      "items": { "$ref": "common.schema.json#/$defs/nonEmptyString" },
      "uniqueItems": true
    },
    "dependencies": {
      "type": "array",
      "items": { "$ref": "common.schema.json#/$defs/nonEmptyString" },
      "uniqueItems": true
    },
    "conflict_keys": {
      "type": "array",
      "items": { "$ref": "common.schema.json#/$defs/nonEmptyString" },
      "uniqueItems": true
    },
    "quality_target": {
      "type": "number",
      "exclusiveMinimum": 0,
      "maximum": 1
    },
    "ambiguities": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["field", "description", "material"],
        "properties": {
          "field": { "$ref": "common.schema.json#/$defs/nonEmptyString" },
          "description": { "$ref": "common.schema.json#/$defs/nonEmptyString" },
          "material": { "type": "boolean" }
        }
      }
    },
    "field_provenance": {
      "type": "object",
      "minProperties": 1,
      "propertyNames": { "minLength": 1 },
      "additionalProperties": { "$ref": "common.schema.json#/$defs/provenance" }
    }
  },
  "allOf": [
    {
      "if": {
        "properties": { "contract_status": { "const": "complete" } },
        "required": ["contract_status"]
      },
      "then": {
        "properties": {
          "targets": { "type": "array", "minItems": 1 },
          "acceptance": { "type": "array", "minItems": 1 },
          "missing_fields": { "type": "array", "maxItems": 0 },
          "ambiguities": {
            "type": "array",
            "not": {
              "contains": {
                "type": "object",
                "properties": { "material": { "const": true } },
                "required": ["material"]
              }
            }
          }
        }
      },
      "else": {
        "properties": { "missing_fields": { "type": "array", "minItems": 1 } }
      }
    }
  ]
}