{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://effort-router.local/schemas/execution-record.schema.json",
  "title": "Privacy-safe execution record",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version", "record_id", "recorded_at", "task_id", "hashes", "profile_ids",
    "route", "versions", "outcome", "latency_ms", "usage", "privacy"
  ],
  "properties": {
    "schema_version": { "const": "1.0.0" },
    "record_id": { "$ref": "common.schema.json#/$defs/nonEmptyString" },
    "recorded_at": { "$ref": "common.schema.json#/$defs/nonEmptyString" },
    "task_id": { "$ref": "common.schema.json#/$defs/nonEmptyString" },
    "hashes": {
      "type": "object",
      "additionalProperties": false,
      "required": ["task", "source", "semantic", "match", "route"],
      "properties": {
        "task": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
        "source": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
        "semantic": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
        "match": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
        "route": { "type": "string", "pattern": "^[a-f0-9]{64}$" }
      }
    },
    "profile_ids": {
      "type": "object",
      "additionalProperties": false,
      "required": ["code", "semantic", "match", "decision"],
      "properties": {
        "code": { "$ref": "common.schema.json#/$defs/nonEmptyString" },
        "semantic": { "$ref": "common.schema.json#/$defs/nonEmptyString" },
        "match": { "$ref": "common.schema.json#/$defs/nonEmptyString" },
        "decision": { "$ref": "common.schema.json#/$defs/nonEmptyString" }
      }
    },
    "route": {
      "type": "object",
      "additionalProperties": false,
      "required": ["action", "model", "effort"],
      "properties": {
        "action": {
          "type": "string",
          "enum": ["dispatch", "request_context", "request_task_contract", "escalate_critic", "human_review"]
        },
        "model": {
          "anyOf": [{ "$ref": "common.schema.json#/$defs/nonEmptyString" }, { "type": "null" }]
        },
        "effort": {
          "anyOf": [{ "$ref": "common.schema.json#/$defs/nonEmptyString" }, { "type": "null" }]
        }
      }
    },
    "versions": { "$ref": "route-decision.schema.json#/properties/versions" },
    "outcome": {
      "type": "object",
      "additionalProperties": false,
      "required": ["acceptance", "tests_passed", "scope_violations", "human_corrections", "success"],
      "properties": {
        "acceptance": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["kind", "passed"],
            "properties": {
              "kind": { "$ref": "common.schema.json#/$defs/nonEmptyString" },
              "passed": { "type": "boolean" }
            }
          }
        },
        "tests_passed": { "type": ["boolean", "null"] },
        "scope_violations": { "type": "integer", "minimum": 0 },
        "human_corrections": { "type": "integer", "minimum": 0 },
        "success": { "type": "boolean" }
      }
    },
    "latency_ms": {
      "type": "object",
      "additionalProperties": false,
      "required": ["critic", "analysis", "actor", "total"],
      "properties": {
        "critic": { "type": ["number", "null"], "minimum": 0 },
        "analysis": { "type": ["number", "null"], "minimum": 0 },
        "actor": { "type": ["number", "null"], "minimum": 0 },
        "total": { "type": ["number", "null"], "minimum": 0 }
      }
    },
    "usage": {
      "type": "object",
      "additionalProperties": false,
      "required": ["input_tokens", "output_tokens", "cache_read_tokens", "cache_write_tokens"],
      "properties": {
        "input_tokens": { "type": ["integer", "null"], "minimum": 0 },
        "output_tokens": { "type": ["integer", "null"], "minimum": 0 },
        "cache_read_tokens": { "type": ["integer", "null"], "minimum": 0 },
        "cache_write_tokens": { "type": ["integer", "null"], "minimum": 0 }
      }
    },
    "privacy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["source_stored", "secrets_stored"],
      "properties": {
        "source_stored": { "const": false },
        "secrets_stored": { "const": false }
      }
    }
  }
}