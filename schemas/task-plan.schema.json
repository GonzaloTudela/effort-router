{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://effort-router.local/schemas/task-plan.schema.json",
  "title": "Task plan",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "id", "tasks"],
  "properties": {
    "schema_version": { "const": "1.0.0" },
    "id": { "$ref": "common.schema.json#/$defs/nonEmptyString" },
    "tasks": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "task-profile.schema.json" }
    }
  }
}