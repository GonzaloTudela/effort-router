{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://effort-router.local/schemas/code-profile.schema.json",
  "title": "CodeProfile",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "profile_id",
    "analyzer",
    "source_hash",
    "files",
    "symbols",
    "calls",
    "state_accesses",
    "effects",
    "dependencies",
    "tests",
    "coverage",
    "evidence"
  ],
  "properties": {
    "schema_version": { "const": "1.0.0" },
    "profile_id": { "$ref": "common.schema.json#/$defs/nonEmptyString" },
    "analyzer": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "version", "language", "rule_versions"],
      "properties": {
        "name": { "$ref": "common.schema.json#/$defs/nonEmptyString" },
        "version": { "$ref": "common.schema.json#/$defs/nonEmptyString" },
        "language": { "$ref": "common.schema.json#/$defs/nonEmptyString" },
        "rule_versions": {
          "type": "object",
          "additionalProperties": { "$ref": "common.schema.json#/$defs/nonEmptyString" }
        }
      }
    },
    "source_hash": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    },
    "files": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["path", "hash", "parsed", "parse_errors"],
        "properties": {
          "path": { "$ref": "common.schema.json#/$defs/nonEmptyString" },
          "hash": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
          "parsed": { "type": "boolean" },
          "parse_errors": {
            "type": "array",
            "items": { "$ref": "common.schema.json#/$defs/nonEmptyString" }
          }
        }
      }
    },
    "symbols": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id", "kind", "name", "qualified_name", "location", "signature",
          "parameters", "return_types", "control_flow"
        ],
        "properties": {
          "id": { "$ref": "common.schema.json#/$defs/nonEmptyString" },
          "kind": {
            "type": "string",
            "enum": ["function", "method", "class", "interface", "trait", "closure", "file"]
          },
          "name": { "$ref": "common.schema.json#/$defs/nonEmptyString" },
          "qualified_name": { "$ref": "common.schema.json#/$defs/nonEmptyString" },
          "location": { "$ref": "common.schema.json#/$defs/location" },
          "signature": { "$ref": "common.schema.json#/$defs/nonEmptyString" },
          "parameters": {
            "type": "array",
            "items": { "$ref": "common.schema.json#/$defs/nonEmptyString" }
          },
          "return_types": {
            "type": "array",
            "items": { "$ref": "common.schema.json#/$defs/nonEmptyString" },
            "uniqueItems": true
          },
          "control_flow": {
            "type": "object",
            "additionalProperties": false,
            "required": ["branch_count", "loop_count", "throw_count", "return_count", "cyclomatic_complexity"],
            "properties": {
              "branch_count": { "type": "integer", "minimum": 0 },
              "loop_count": { "type": "integer", "minimum": 0 },
              "throw_count": { "type": "integer", "minimum": 0 },
              "return_count": { "type": "integer", "minimum": 0 },
              "cyclomatic_complexity": { "type": "integer", "minimum": 1 }
            }
          }
        }
      }
    },
    "calls": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "caller_symbol_id", "callee", "resolved_symbol_id", "resolved", "dynamic", "location"],
        "properties": {
          "id": { "$ref": "common.schema.json#/$defs/nonEmptyString" },
          "caller_symbol_id": { "$ref": "common.schema.json#/$defs/nonEmptyString" },
          "callee": { "$ref": "common.schema.json#/$defs/nonEmptyString" },
          "resolved_symbol_id": {
            "anyOf": [
              { "$ref": "common.schema.json#/$defs/nonEmptyString" },
              { "type": "null" }
            ]
          },
          "resolved": { "type": "boolean" },
          "dynamic": { "type": "boolean" },
          "location": { "$ref": "common.schema.json#/$defs/location" }
        }
      }
    },
    "state_accesses": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "symbol_id", "subject", "scope", "access", "location"],
        "properties": {
          "id": { "$ref": "common.schema.json#/$defs/nonEmptyString" },
          "symbol_id": { "$ref": "common.schema.json#/$defs/nonEmptyString" },
          "subject": { "$ref": "common.schema.json#/$defs/nonEmptyString" },
          "scope": { "type": "string", "enum": ["local", "property", "static", "global", "external"] },
          "access": { "type": "string", "enum": ["read", "write", "read_write"] },
          "location": { "$ref": "common.schema.json#/$defs/location" }
        }
      }
    },
    "effects": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "symbol_id", "kind", "operation", "location", "rule_id"],
        "properties": {
          "id": { "$ref": "common.schema.json#/$defs/nonEmptyString" },
          "symbol_id": { "$ref": "common.schema.json#/$defs/nonEmptyString" },
          "kind": { "$ref": "common.schema.json#/$defs/effectKind" },
          "operation": { "$ref": "common.schema.json#/$defs/nonEmptyString" },
          "location": { "$ref": "common.schema.json#/$defs/location" },
          "rule_id": { "$ref": "common.schema.json#/$defs/nonEmptyString" }
        }
      }
    },
    "dependencies": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "from_symbol_id", "target", "kind", "resolved"],
        "properties": {
          "id": { "$ref": "common.schema.json#/$defs/nonEmptyString" },
          "from_symbol_id": { "$ref": "common.schema.json#/$defs/nonEmptyString" },
          "target": { "$ref": "common.schema.json#/$defs/nonEmptyString" },
          "kind": { "type": "string", "enum": ["internal", "framework", "runtime", "package"] },
          "resolved": { "type": "boolean" }
        }
      }
    },
    "tests": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["path", "symbol_ids", "commands"],
        "properties": {
          "path": { "$ref": "common.schema.json#/$defs/nonEmptyString" },
          "symbol_ids": {
            "type": "array",
            "items": { "$ref": "common.schema.json#/$defs/nonEmptyString" },
            "uniqueItems": true
          },
          "commands": {
            "type": "array",
            "items": { "$ref": "common.schema.json#/$defs/nonEmptyString" },
            "uniqueItems": true
          }
        }
      }
    },
    "coverage": {
      "type": "object",
      "additionalProperties": false,
      "required": ["files_total", "files_parsed", "calls_total", "calls_resolved", "unresolved_call_ids", "dynamic_constructs", "bounded"],
      "properties": {
        "files_total": { "type": "integer", "minimum": 0 },
        "files_parsed": { "type": "integer", "minimum": 0 },
        "calls_total": { "type": "integer", "minimum": 0 },
        "calls_resolved": { "type": "integer", "minimum": 0 },
        "unresolved_call_ids": {
          "type": "array",
          "items": { "$ref": "common.schema.json#/$defs/nonEmptyString" },
          "uniqueItems": true
        },
        "dynamic_constructs": { "type": "integer", "minimum": 0 },
        "bounded": { "type": "boolean" }
      }
    },
    "evidence": {
      "type": "array",
      "items": { "$ref": "common.schema.json#/$defs/evidence" }
    }
  }
}